# Environment profile: dev | paper | testnet | canary_live | production
GUARDRAIL_ENV=dev

# OPA
OPA_URL=http://localhost:8181

# Guardrail decision and audit signing secrets (use high-entropy values outside dev)
GUARDRAIL_DECISION_SECRET=dev-decision-secret
AUDIT_HASH_SECRET=dev-audit-hash-secret

# Vault (dev server only — never use dev mode in production)
VAULT_ADDR=http://127.0.0.1:8200
VAULT_TOKEN=replace-me-dev-only

# Binance (no real keys — use Vault in non-dev environments)
BINANCE_API_KEY=your-api-key-here
BINANCE_API_SECRET=your-api-secret-here
BINANCE_TESTNET=true

# Reviewer
REVIEWER_PROVIDER=openai
REVIEWER_MODEL=gpt-5.5

# Audit
AUDIT_DB_PATH=./data/audit.db
# Required outside dev/test; store separately from the SQLite DB and back it up after writes.
AUDIT_HASH_ANCHOR_PATH=./audit-anchor/audit-head.hash

# Human Approval
APPROVAL_TIMEOUT_SECONDS=300
