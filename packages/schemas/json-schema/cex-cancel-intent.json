{
  "$ref": "#/definitions/cex-cancel-intent",
  "definitions": {
    "cex-cancel-intent": {
      "type": "object",
      "properties": {
        "intentId": {
          "type": "string",
          "format": "uuid"
        },
        "principal": {
          "type": "string",
          "minLength": 1
        },
        "action": {
          "type": "string",
          "const": "cex.cancel_order"
        },
        "resource": {
          "type": "string",
          "minLength": 1
        },
        "environment": {
          "type": "string",
          "enum": ["dev", "paper", "testnet", "canary_live", "production"]
        },
        "requestedAt": {
          "type": "string",
          "format": "date-time"
        },
        "idempotencyKey": {
          "type": "string",
          "minLength": 1
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "exchange": {
          "type": "string",
          "const": "binance"
        },
        "account": {
          "type": "string",
          "minLength": 1
        },
        "orderId": {
          "type": "string",
          "minLength": 1
        },
        "symbol": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "intentId",
        "principal",
        "action",
        "resource",
        "environment",
        "requestedAt",
        "idempotencyKey",
        "rationale",
        "evidence",
        "exchange",
        "account",
        "orderId",
        "symbol"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
