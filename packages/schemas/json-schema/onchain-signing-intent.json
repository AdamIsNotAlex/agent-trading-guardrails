{
  "$ref": "#/definitions/onchain-signing-intent",
  "definitions": {
    "onchain-signing-intent": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "intentId": {
              "type": "string",
              "format": "uuid"
            },
            "principal": {
              "type": "string",
              "minLength": 1
            },
            "action": {
              "type": "string",
              "const": "onchain.request_signature"
            },
            "resource": {
              "type": "string",
              "minLength": 1
            },
            "environment": {
              "type": "string",
              "enum": ["dev", "paper", "testnet", "canary_live", "production"]
            },
            "requestedAt": {
              "type": "string",
              "format": "date-time"
            },
            "idempotencyKey": {
              "type": "string",
              "minLength": 1
            },
            "rationale": {
              "type": "string",
              "minLength": 1
            },
            "evidence": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "minItems": 1
            },
            "chainEnvironment": {
              "type": "string",
              "enum": ["sepolia", "devnet", "mainnet"]
            },
            "to": {
              "type": "string",
              "minLength": 1
            },
            "data": {
              "type": "string"
            },
            "value": {
              "type": "string"
            },
            "programId": {
              "type": "string"
            },
            "instructions": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": {}
              }
            },
            "simulationId": {
              "type": "string",
              "format": "uuid"
            },
            "maxTokenApprovalAmount": {
              "type": "string"
            },
            "chain": {
              "type": "string",
              "const": "ethereum"
            },
            "expectedDeltas": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "address": {
                    "type": "string",
                    "minLength": 1
                  },
                  "asset": {
                    "type": "string",
                    "minLength": 1
                  },
                  "minDelta": {
                    "type": "string",
                    "pattern": "^-?\\d+$"
                  },
                  "maxDelta": {
                    "$ref": "#/definitions/onchain-signing-intent/anyOf/0/properties/expectedDeltas/items/properties/minDelta"
                  }
                },
                "required": ["address", "asset", "minDelta", "maxDelta"],
                "additionalProperties": false
              },
              "minItems": 1
            }
          },
          "required": [
            "intentId",
            "principal",
            "action",
            "resource",
            "environment",
            "requestedAt",
            "idempotencyKey",
            "rationale",
            "evidence",
            "chainEnvironment",
            "to",
            "simulationId",
            "chain",
            "expectedDeltas"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "intentId": {
              "$ref": "#/definitions/onchain-signing-intent/anyOf/0/properties/intentId"
            },
            "principal": {
              "$ref": "#/definitions/onchain-signing-intent/anyOf/0/properties/principal"
            },
            "action": {
              "$ref": "#/definitions/onchain-signing-intent/anyOf/0/properties/action"
            },
            "resource": {
              "$ref": "#/definitions/onchain-signing-intent/anyOf/0/properties/resource"
            },
            "environment": {
              "$ref": "#/definitions/onchain-signing-intent/anyOf/0/properties/environment"
            },
            "requestedAt": {
              "$ref": "#/definitions/onchain-signing-intent/anyOf/0/properties/requestedAt"
            },
            "idempotencyKey": {
              "$ref": "#/definitions/onchain-signing-intent/anyOf/0/properties/idempotencyKey"
            },
            "rationale": {
              "$ref": "#/definitions/onchain-signing-intent/anyOf/0/properties/rationale"
            },
            "evidence": {
              "$ref": "#/definitions/onchain-signing-intent/anyOf/0/properties/evidence"
            },
            "chainEnvironment": {
              "$ref": "#/definitions/onchain-signing-intent/anyOf/0/properties/chainEnvironment"
            },
            "to": {
              "$ref": "#/definitions/onchain-signing-intent/anyOf/0/properties/to"
            },
            "data": {
              "$ref": "#/definitions/onchain-signing-intent/anyOf/0/properties/data"
            },
            "value": {
              "$ref": "#/definitions/onchain-signing-intent/anyOf/0/properties/value"
            },
            "programId": {
              "type": "string",
              "minLength": 1
            },
            "instructions": {
              "$ref": "#/definitions/onchain-signing-intent/anyOf/0/properties/instructions"
            },
            "simulationId": {
              "$ref": "#/definitions/onchain-signing-intent/anyOf/0/properties/simulationId"
            },
            "maxTokenApprovalAmount": {
              "$ref": "#/definitions/onchain-signing-intent/anyOf/0/properties/maxTokenApprovalAmount"
            },
            "chain": {
              "type": "string",
              "const": "solana"
            },
            "expectedDeltas": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "account": {
                    "type": "string",
                    "minLength": 1
                  },
                  "asset": {
                    "type": "string",
                    "minLength": 1
                  },
                  "minDelta": {
                    "$ref": "#/definitions/onchain-signing-intent/anyOf/0/properties/expectedDeltas/items/properties/minDelta"
                  },
                  "maxDelta": {
                    "$ref": "#/definitions/onchain-signing-intent/anyOf/0/properties/expectedDeltas/items/properties/minDelta"
                  }
                },
                "required": ["account", "asset", "minDelta", "maxDelta"],
                "additionalProperties": false
              },
              "minItems": 1
            }
          },
          "required": [
            "intentId",
            "principal",
            "action",
            "resource",
            "environment",
            "requestedAt",
            "idempotencyKey",
            "rationale",
            "evidence",
            "chainEnvironment",
            "to",
            "programId",
            "simulationId",
            "chain",
            "expectedDeltas"
          ],
          "additionalProperties": false
        }
      ]
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
