{
  "$ref": "#/definitions/dynamic-risk-result",
  "definitions": {
    "dynamic-risk-result": {
      "type": "object",
      "properties": {
        "intentId": {
          "type": "string",
          "format": "uuid"
        },
        "passed": {
          "type": "boolean"
        },
        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "check": {
                "type": "string",
                "minLength": 1
              },
              "status": {
                "type": "string",
                "enum": ["pass", "fail", "unavailable"]
              },
              "value": {},
              "threshold": {},
              "message": {
                "type": "string"
              }
            },
            "required": ["check", "status"],
            "additionalProperties": false
          }
        },
        "evaluatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["intentId", "passed", "checks", "evaluatedAt"],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
