{
  "$ref": "#/definitions/broker-execution-result",
  "definitions": {
    "broker-execution-result": {
      "type": "object",
      "properties": {
        "intentId": {
          "type": "string",
          "format": "uuid"
        },
        "idempotencyKey": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["executed", "rejected", "failed"]
        },
        "orderId": {
          "type": "string"
        },
        "transactionHash": {
          "type": "string"
        },
        "orderStatus": {
          "type": "object",
          "properties": {
            "orderId": {
              "type": "string",
              "minLength": 1
            },
            "symbol": {
              "type": "string",
              "minLength": 1
            },
            "side": {
              "type": "string",
              "minLength": 1
            },
            "status": {
              "type": "string",
              "minLength": 1
            },
            "executedQty": {
              "type": "number",
              "minimum": 0
            },
            "avgPrice": {
              "type": "number",
              "minimum": 0
            }
          },
          "required": ["orderId", "symbol", "side", "status", "executedQty", "avgPrice"],
          "additionalProperties": false
        },
        "revalidationPassed": {
          "type": "boolean"
        },
        "rejectionReason": {
          "type": "string"
        },
        "executedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["intentId", "idempotencyKey", "status", "revalidationPassed", "executedAt"],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
