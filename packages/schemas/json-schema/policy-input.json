{
  "$ref": "#/definitions/policy-input",
  "definitions": {
    "policy-input": {
      "type": "object",
      "properties": {
        "intentId": {
          "type": "string",
          "format": "uuid"
        },
        "principal": {
          "type": "string",
          "minLength": 1
        },
        "action": {
          "type": "string",
          "minLength": 1
        },
        "resource": {
          "type": "string",
          "minLength": 1
        },
        "environment": {
          "type": "string",
          "enum": ["dev", "paper", "testnet", "canary_live", "production"]
        },
        "accountMode": {
          "type": "string"
        },
        "marginType": {
          "type": "string"
        },
        "exchange": {
          "type": "string"
        },
        "symbol": {
          "type": "string"
        },
        "chain": {
          "type": "string"
        },
        "chainEnvironment": {
          "type": "string"
        },
        "contractAddress": {
          "type": "string"
        },
        "programId": {
          "type": "string"
        },
        "instructionType": {
          "type": "string"
        },
        "maxNotionalUsd": {
          "type": "number"
        },
        "leverage": {
          "type": "number"
        },
        "maxTokenApprovalAmount": {
          "type": "string"
        },
        "isTokenApproval": {
          "type": "boolean"
        },
        "tokenApprovalAmount": {
          "type": ["string", "null"]
        },
        "tokenApprovalAmountMissing": {
          "type": "boolean"
        },
        "tokenApprovalUnlimited": {
          "type": "boolean"
        },
        "tokenApprovalAmountExceedsCap": {
          "type": "boolean"
        },
        "reviewerVerdict": {
          "type": "string"
        },
        "reviewerRiskLevel": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "reviewerDetectedIssues": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "riskCheckResults": {
          "type": "object",
          "additionalProperties": {}
        },
        "dailyNotionalUsd": {
          "type": "number"
        },
        "projectedDailyNotionalUsd": {
          "type": "number"
        },
        "dailyRealizedLossUsd": {
          "type": "number"
        }
      },
      "required": ["intentId", "principal", "action", "resource", "environment"],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
